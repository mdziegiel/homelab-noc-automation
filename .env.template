# ============================================================================
# Homelab Monitoring Stack — Environment Template
# ============================================================================
# Copy this file to .env and fill in YOUR real values. NEVER commit .env.
#   cp .env.template .env && chmod 600 .env
#
# The .env lives at ~/.hermes/.env on the control node. Every script and the
# NOC dashboard reads its hosts + credentials from here. All placeholder IPs
# use the sanitized RFC1918 range 10.0.0.0/24 — replace with your real subnet.
# ============================================================================

# ---------------------------------------------------------------------------
# INFRASTRUCTURE HOSTS  (IP or hostname of each box/service)
# ---------------------------------------------------------------------------
UNIFI_HOST=YOUR_UNIFI_GATEWAY_IP            # UniFi UDM/controller (e.g. 10.0.0.1)
ADGUARD_HOST=YOUR_ADGUARD_IP                # AdGuard Home primary (e.g. 10.0.0.21)
URBACKUP_HOST=YOUR_URBACKUP_IP              # URBackup server (e.g. 10.0.0.76)
PBS_HOST=YOUR_PBS_IP                        # Proxmox Backup Server (e.g. 10.0.0.77)
WAZUH_HOST=YOUR_WAZUH_IP                    # Wazuh manager+indexer (e.g. 10.0.0.233)
HERMES_HOST=YOUR_CONTROL_NODE_IP            # This control node / dashboard host (e.g. 10.0.0.234)
DOCKER_HOST_IP=YOUR_DOCKER_HOST_IP          # Docker/Portainer/CrowdSec/Gotify host (e.g. 10.0.0.237)
PROXMOX_HOST=YOUR_PROXMOX_IP                # Proxmox VE node (e.g. 10.0.0.251)

# ---------------------------------------------------------------------------
# PROXMOX VE  (API token auth — Datacenter > Permissions > API Tokens)
# ---------------------------------------------------------------------------
PROXMOX_TOKEN_ID=YOUR_PROXMOX_TOKEN_ID          # e.g. root@pam!monitoring
PROXMOX_TOKEN_SECRET=YOUR_PROXMOX_TOKEN_SECRET  # the token UUID secret

# ---------------------------------------------------------------------------
# PROXMOX BACKUP SERVER
# ---------------------------------------------------------------------------
PBS_USERNAME=YOUR_PBS_USERNAME              # e.g. root@pam
PBS_PASSWORD=YOUR_PBS_PASSWORD

# ---------------------------------------------------------------------------
# WAZUH  (SIEM manager API + indexer/OpenSearch)
# ---------------------------------------------------------------------------
WAZUH_API_USER=YOUR_WAZUH_API_USER          # manager API user (read-only recommended)
WAZUH_API_PASSWORD=YOUR_WAZUH_API_PASSWORD
WAZUH_INDEXER_HOST=https://YOUR_WAZUH_IP:9200
WAZUH_INDEXER_USER=YOUR_INDEXER_RO_USER     # scoped read-only role on wazuh-alerts-*
WAZUH_INDEXER_PASS=YOUR_INDEXER_RO_PASSWORD

# ---------------------------------------------------------------------------
# CROWDSEC  (LAPI + console)
# ---------------------------------------------------------------------------
CROWDSEC_API_KEY=YOUR_CROWDSEC_BOUNCER_API_KEY     # cscli bouncers add
CROWDSEC_MACHINE_USER=YOUR_CROWDSEC_MACHINE_USER   # for /v1/alerts access
CROWDSEC_MACHINE_PASS=YOUR_CROWDSEC_MACHINE_PASS

# ---------------------------------------------------------------------------
# UNIFI NETWORK  (local admin account, no 2FA for API)
# ---------------------------------------------------------------------------
UNIFI_USERNAME=YOUR_UNIFI_USERNAME
UNIFI_PASSWORD=YOUR_UNIFI_PASSWORD

# ---------------------------------------------------------------------------
# ADGUARD HOME  (primary + optional secondary DNS2)
# ---------------------------------------------------------------------------
ADGUARD_PASSWORD=YOUR_ADGUARD_PASSWORD
ADGUARD2_URL=http://YOUR_ADGUARD2_IP
ADGUARD2_USERNAME=YOUR_ADGUARD2_USERNAME
ADGUARD2_PASSWORD=YOUR_ADGUARD2_PASSWORD

# ---------------------------------------------------------------------------
# TAILSCALE  (API key for device/key-expiry monitoring)
# ---------------------------------------------------------------------------
TAILSCALE_API_KEY=YOUR_TAILSCALE_API_KEY

# ---------------------------------------------------------------------------
# CLOUDFLARE  (scoped API token: Analytics + Firewall read)
# ---------------------------------------------------------------------------
CLOUDFLARE_TOKEN=YOUR_CLOUDFLARE_API_TOKEN
CLOUDFLARE_ZONE_ID=YOUR_CLOUDFLARE_ZONE_ID

# ---------------------------------------------------------------------------
# PORTAINER  (Docker management API)
# ---------------------------------------------------------------------------
PORTAINER_URL=https://YOUR_DOCKER_HOST_IP:9443
PORTAINER_USERNAME=YOUR_PORTAINER_USERNAME
PORTAINER_PASSWORD=YOUR_PORTAINER_PASSWORD

# ---------------------------------------------------------------------------
# UPTIME KUMA  (status page metrics — API key as basic-auth password)
# ---------------------------------------------------------------------------
UPTIME_KUMA_URL=http://YOUR_DOCKER_HOST_IP:3001
UPTIME_KUMA_API_KEY=YOUR_UPTIME_KUMA_API_KEY

# ---------------------------------------------------------------------------
# NGINX PROXY MANAGER
# ---------------------------------------------------------------------------
NPM_URL=http://YOUR_DOCKER_HOST_IP:81
NPM_EMAIL=YOUR_NPM_EMAIL
NPM_PASSWORD=YOUR_NPM_PASSWORD

# ---------------------------------------------------------------------------
# WG-DASHBOARD  (WireGuard)
# ---------------------------------------------------------------------------
WGDASHBOARD_URL=http://YOUR_WIREGUARD_IP:10086
WGDASHBOARD_USERNAME=YOUR_WGDASHBOARD_USERNAME
WGDASHBOARD_PASSWORD=YOUR_WGDASHBOARD_PASSWORD

# ---------------------------------------------------------------------------
# HOME ASSISTANT  (long-lived access token)
# ---------------------------------------------------------------------------
HASS_URL=http://YOUR_HOMEASSISTANT_IP:8123
HASS_TOKEN=YOUR_HOME_ASSISTANT_LONG_LIVED_TOKEN

# ---------------------------------------------------------------------------
# PLEX / TAUTULLI / *ARR MEDIA STACK
# ---------------------------------------------------------------------------
PLEX_URL=http://YOUR_PLEX_IP:32400
PLEX_TOKEN=YOUR_PLEX_TOKEN
TAUTULLI_URL=http://YOUR_TAUTULLI_IP:8181
TAUTULLI_API_KEY=YOUR_TAUTULLI_API_KEY
SABNZBD_URL=http://YOUR_SABNZBD_IP:8080
SABNZBD_API_KEY=YOUR_SABNZBD_API_KEY
OVERSEERR_URL=http://YOUR_OVERSEERR_IP:5055
OVERSEERR_API_KEY=YOUR_OVERSEERR_API_KEY

# ---------------------------------------------------------------------------
# QNAP NAS  (three units)
# ---------------------------------------------------------------------------
QNAP1_HOST=YOUR_QNAP1_IP
QNAP2_HOST=YOUR_QNAP2_IP
QNAP3_HOST=YOUR_QNAP3_IP
QNAP_USERNAME=YOUR_QNAP_USERNAME
QNAP_PASSWORD=YOUR_QNAP_PASSWORD

# ---------------------------------------------------------------------------
# URBACKUP
# ---------------------------------------------------------------------------
URBACKUP_URL=http://YOUR_URBACKUP_IP:55414
URBACKUP_USERNAME=YOUR_URBACKUP_USERNAME
URBACKUP_PASSWORD=YOUR_URBACKUP_PASSWORD

# ---------------------------------------------------------------------------
# GOTIFY  (push notifications — second alert channel)
# ---------------------------------------------------------------------------
GOTIFY_URL=http://YOUR_DOCKER_HOST_IP:10143
GOTIFY_TOKEN=YOUR_GOTIFY_APP_TOKEN          # application token (sends messages)
GOTIFY_CLIENT_TOKEN=YOUR_GOTIFY_CLIENT_TOKEN # client token (reads messages)

# ---------------------------------------------------------------------------
# TELEGRAM  (primary alert channel + Wazuh integration)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN  # from @BotFather, format 123456789:ABC...
TELEGRAM_HOME_CHANNEL=YOUR_TELEGRAM_CHAT_ID # numeric chat id (your DM or group)
