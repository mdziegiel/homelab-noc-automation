# ============================================================
# Secrets & environment — NEVER commit real values
# ============================================================
.env
.env.*
!.env.template
*.env
secrets/
credentials/
*.key
*.pem
*.crt
*.p12
*token*
*secret*

# ============================================================
# State, caches, runtime artifacts
# ============================================================
state/
*.state
dashboard_trends.json
*.bak
*.bak.*
*.bak-*
*.noncanonical-bak-*
*.backup
*.removed
__pycache__/
*.py[cod]
*$py.class
.mypy_cache/
.pytest_cache/

# ============================================================
# Generated output
# ============================================================
index.html
homelab-dashboard/
*.log
logs/

